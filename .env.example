# Public Expo variables bundled with the app.
# Do not put private secrets here.
EXPO_PUBLIC_API_URL=http://localhost:8080

# Opcional. Se ficar vazio, o app usa o mesmo host da API e troca a porta para 5173.
# Em celular fisico, use o IP da sua maquina ou a porta real do Vite.
# EXPO_PUBLIC_WEB_URL=http://192.168.0.10:5173
