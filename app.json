{
  "expo": {
    "name": "TimerBook",
    "slug": "timerbook-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0b1221"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "usesCleartextTraffic": true
    },
    "web": {
      "bundler": "metro"
    }
  }
}
